# ----------------------------------------------------------------------
# Muskelkater — Umgebungsvariablen
# Kopiere diese Datei nach `.env.local` und trage deine Supabase-Werte ein.
# (.env.local wird von Git ignoriert.)
# ----------------------------------------------------------------------

# Supabase: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://DEIN-PROJEKT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="dein-anon-public-key"

# Supabase: Project Settings → Database → Connection string → "Transaction"
# (Pooler-URL, Port 6543). Passwort einsetzen, sslmode=require anhängen.
# Wird ausschließlich serverseitig von Drizzle verwendet.
DATABASE_URL="postgresql://postgres.DEIN-PROJEKT:DEIN-DB-PASSWORT@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require"

# Optional: Basis-URL für E-Mail-Bestätigungslinks (Default: Request-Origin)
# NEXT_PUBLIC_SITE_URL="http://localhost:3000"
